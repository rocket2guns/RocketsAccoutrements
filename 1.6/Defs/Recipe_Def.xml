<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--  RECIPE BASE  -->

	<RecipeDef Name="ROCKET_MedalRecipeBase" Abstract="True">
		<workAmount>10000</workAmount>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<workSkill>Crafting</workSkill>
		<effectWorking>Smith</effectWorking>
		<soundWorking>Recipe_Smith</soundWorking>
		<recipeUsers>
			<li>ElectricSmithy</li>
			<li>FueledSmithy</li>
		</recipeUsers>
		<researchPrerequisites>
			<li>Smithing</li>
		</researchPrerequisites>
	</RecipeDef>

	<!--  TIER RECIPE BASES  -->

	<RecipeDef ParentName="ROCKET_MedalRecipeBase" Name="ROCKET_SimpleMedalRecipeBase" Abstract="True">
		<skillRequirements>
			<Crafting>5</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<thingDefs><li>Silver</li></thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<thingDefs><li>DevilstrandCloth</li></thingDefs>
				</filter>
				<count>10</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Silver</li>
				<li>DevilstrandCloth</li>
			</thingDefs>
		</fixedIngredientFilter>
		<researchPrerequisites>
			<li>NobleApparel</li>
		</researchPrerequisites>
	</RecipeDef>

