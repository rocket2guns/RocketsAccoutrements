<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  
  <Operation Class="VEF.PatchOperationToggableSequence">
    
	<enabled>True</enabled>
	
    <label>accessory items occupy an extra layer</label>
	
    <operations>
	
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[@Name="ROCKET_Ranks"]/apparel/layers/li[1]</xpath>
        <value>
		  <li>VFEC_OuterShell</li>
        </value>
      </li>
	  <li Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[@Name="ROCKET_RanksROCKET_Ranks"]/apparel</xpath>
        <value>		  
		  <drawData>
			<dataNorth>
			  <layer>89</layer>
			</dataNorth>
		  </drawData>
        </value>
      </li>
	  
    </operations>
  </Operation>
  
</Patch>